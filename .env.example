# 0G Compute / testnet Qwen provider
0G_COMPUTE_PROVIDER=0xa48f01287233509FD694a22Bf840225062E67836
0G_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# Fill this after running: 0g-compute-cli inference get-secret --provider $0G_COMPUTE_PROVIDER
0G_COMPUTE_BEARER_TOKEN=

# Best practice: leave blank and let the SDK discover it via getServiceMetadata(provider).
# Alternative local proxy mode: http://localhost:3000 after running 0g-compute-cli inference serve.
0G_COMPUTE_SERVICE_URL=

